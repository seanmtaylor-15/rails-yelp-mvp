<div class="container mt-4">
  <h1><%= @restaurant.name %></h1>

  <p><strong>Address:</strong> <%= @restaurant.address %></p>
  <p><strong>Phone number:</strong> <%= @restaurant.phone_number %></p>
  <p><strong>Category:</strong> <%= @restaurant.category %></p>

  <hr>

  <h2>Reviews</h2>

  <%= link_to "Add a review", new_restaurant_review_path(@restaurant), class: "btn btn-primary mb-3" %>

  <ul class="list-group mb-3">
    <% @restaurant.reviews.each do |review| %>
      <li class="list-group-item">
        <strong><%= review.rating %>/5</strong>
        <p><%= review.content %></p>
      </li>
    <% end %>
  </ul>

  <%= link_to "Back to restaurants", restaurants_path, class: "btn btn-secondary" %>
</div>
